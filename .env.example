# Application
APP_ENV=development
APP_DEBUG=true
TZ=Europe/Minsk
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_HOSTS=["*"]

# Database (SQLite по умолчанию, без настройки)
DATABASE_URL=sqlite+aiosqlite:///./crm.db

# PostgreSQL (когда понадобится):
# DATABASE_URL=postgresql+asyncpg://crm_user:crm_pass@localhost:5432/crm_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# SMS (SMS.ru)
SMS_API_KEY=your-sms-api-key
SMS_SENDER=CRM

# Telephony (Zadarma)
TELEPHONY_API_KEY=your-telephony-key
TELEPHONY_API_SECRET=your-telephony-secret
TELEPHONY_WEBHOOK_SECRET=your-webhook-secret
MTS_VATS_WEBHOOK_TOKEN=your-mts-vats-webhook-token

# Payment (YooKassa)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_SECRET=your-webhook-secret

# Site integration
SITE_WEBHOOK_SECRET=your-site-webhook-secret

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
